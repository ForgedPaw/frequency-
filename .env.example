# Copy this file to .env for local development (`vercel dev` reads it for
# both client VITE_ vars and server-side vars used by api/trivia.js).
# In production, set these in the Vercel dashboard / `vercel env add` instead.

# Spotify Developer Dashboard → your app → Client ID (PKCE needs no secret)
VITE_SPOTIFY_CLIENT_ID=

# console.anthropic.com → API Keys — server-side only, never exposed to the client
ANTHROPIC_API_KEY=
